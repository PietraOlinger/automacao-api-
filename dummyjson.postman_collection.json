{
  "info": {
    "name": "DummyJSON API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login e validar usuário",
      "item": [
        {
          "name": "Login - Capturar token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"emilys\",\n  \"password\": \"emilyspass\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Tempo menor que 2 segundos', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Resposta possui token e dados do usuário', function () {",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('username');",
                  "});",
                  "",
                  "pm.environment.set('token', json.accessToken);",
                  "pm.environment.set('authUserId', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Validar usuário autenticado",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status deve ser 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Tempo menor que 2 segundos', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Usuário autenticado possui campos corretos', function () {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('username');",
                  "  pm.expect(json).to.have.property('email');",
                  "});",
                  "",
                  "pm.test('Token pertence ao usuário correto', function () {",
                  "  pm.expect(json.id).to.eql(Number(pm.environment.get('authUserId')));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
